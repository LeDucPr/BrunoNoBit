meta {
  name: CategorySearch
  type: http
  seq: 1
}

post {
  url: {{cms-localhost}}/api/Category/CategorySearch
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
      "Keyword": "",
      // "CategoryId": null,
      "IsOnlyShowBaseCategory" : false,
      "IsOnlyShowVariantCategory": false,
      "IsFlattenBaseCategory": true,
      "RecursiveDepth": -1,
      "PageSize": 10,
      "PageIndex": 0
  }
}

settings {
  encodeUrl: true
}
