meta {
  name: RefreshToken
  type: http
  seq: 6
}

post {
  url: {{sso-localhost}}/api/Account/RefreshToken
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
      "RefreshToken": "{{refreshToken}}",
      "AuthType": {{authType}}
  }
}

script:post-response {
  let jsonData = res.getBody();
  bru.setGlobalEnvVar("token", jsonData.data.model.token);
  bru.setGlobalEnvVar("refreshToken", jsonData.data.model.refreshToken);
}

settings {
  encodeUrl: true
}
